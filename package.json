{
  "name": "roadmap-skilltree-builder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:unit": "vitest components/skill-tree/__tests__ --exclude components/skill-tree/__tests__/segmentIntegration.test.js --exclude components/skill-tree/__tests__/multiselect.test.js",
    "test:integration": "vitest components/skill-tree/__tests__/segmentIntegration.test.js components/skill-tree/__tests__/multiselect.test.js",
    "test:regression": "vitest components/skill-tree/__tests__/layoutSolver.test.js components/skill-tree/__tests__/treeValidation.test.js components/skill-tree/__tests__/treeData.test.js components/skill-tree/__tests__/documentState.test.js components/skill-tree/__tests__/documentPersistence.test.js components/skill-tree/__tests__/htmlExport.test.js components/skill-tree/__tests__/pdfExport.test.js components/skill-tree/__tests__/svgExport.test.js components/skill-tree/__tests__/nodeSegmentAssignment.test.js components/skill-tree/__tests__/segmentSlots.test.js",
    "test:ui": "vitest --ui",
    "preview": "vite preview",
    "test:e2e": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports playwright test",
    "test:e2e:ui": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports playwright test --ui",
    "test:e2e:update-snapshots": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports playwright test --update-snapshots",
    "test:e2e:csv": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports SKILLTREE_E2E_METRICS_DIR=tests/results/e2e-metrics SKILLTREE_E2E_DATASET=large playwright test tests/e2e/csv-import-export-roundtrip.spec.js --project=chromium",
    "test:e2e:csv:headed": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports SKILLTREE_E2E_METRICS_DIR=tests/results/e2e-metrics SKILLTREE_E2E_DATASET=large playwright test tests/e2e/csv-import-export-roundtrip.spec.js --project=chromium --headed",
    "test:e2e:csv:small": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports SKILLTREE_E2E_METRICS_DIR=tests/results/e2e-metrics SKILLTREE_E2E_DATASET=small playwright test tests/e2e/csv-import-export-roundtrip.spec.js --project=chromium",
    "test:e2e:csv:medium": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports SKILLTREE_E2E_METRICS_DIR=tests/results/e2e-metrics SKILLTREE_E2E_DATASET=medium playwright test tests/e2e/csv-import-export-roundtrip.spec.js --project=chromium",
    "test:e2e:csv:large": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports SKILLTREE_E2E_METRICS_DIR=tests/results/e2e-metrics SKILLTREE_E2E_DATASET=large playwright test tests/e2e/csv-import-export-roundtrip.spec.js --project=chromium",
    "test:e2e:csv:phases": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports SKILLTREE_E2E_METRICS_DIR=tests/results/e2e-metrics SKILLTREE_E2E_DATASET=large SKILLTREE_E2E_PHASES=statuses,scopes,segments,roundtrip playwright test tests/e2e/csv-import-export-roundtrip.spec.js --project=chromium",
    "test:e2e:csv:custom": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports SKILLTREE_E2E_METRICS_DIR=tests/results/e2e-metrics SKILLTREE_E2E_DATASET=custom playwright test tests/e2e/csv-import-export-roundtrip.spec.js --project=chromium",
    "test:phase2": "SKILLTREE_TEST_ARTIFACTS_DIR=tests/results SKILLTREE_E2E_EXPORT_DIR=tests/results/e2e-exports playwright test tests/e2e/csv-import-export-roundtrip.spec.js tests/e2e/undoRedo.spec.js tests/e2e/segment-toolbar.spec.js tests/e2e/exports.spec.js --project=chromium --reporter=list",
    "test:phase3:core": "vitest run components/skill-tree/__tests__/layoutSolver.test.js components/skill-tree/__tests__/treeValidation.test.js components/skill-tree/__tests__/treeData.test.js components/skill-tree/__tests__/documentState.test.js components/skill-tree/__tests__/documentPersistence.test.js components/skill-tree/__tests__/htmlExport.test.js components/skill-tree/__tests__/pdfExport.test.js components/skill-tree/__tests__/svgExport.test.js components/skill-tree/__tests__/nodeSegmentAssignment.test.js components/skill-tree/__tests__/segmentSlots.test.js components/skill-tree/__tests__/phase3Regression.test.js",
    "test:phase3:integration": "vitest run components/skill-tree/__tests__/segmentCRUD.test.js components/skill-tree/__tests__/segmentIntegration.test.js components/skill-tree/__tests__/multiselect.test.js components/skill-tree/__tests__/keyboardShortcuts.test.js components/skill-tree/__tests__/panelsState.test.js components/skill-tree/__tests__/inspector.test.js",
    "test:phase3": "npm run test:phase3:core && npm run test:phase3:integration"
  },
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@tabler/icons-react": "^3.40.0",
    "d3-hierarchy": "^3.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-zoom-pan-pinch": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
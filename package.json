{
  "name": "roadmap-skilltree-builder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:csv": "playwright test e2e/csv-import-export-roundtrip.spec.js --project=chromium",
    "test:e2e:csv:headed": "playwright test e2e/csv-import-export-roundtrip.spec.js --project=chromium --headed",
    "test:e2e:csv:ignore-levels": "SKILLTREE_E2E_IGNORE_MANUAL_LEVELS=1 playwright test e2e/csv-import-export-roundtrip.spec.js --project=chromium",
    "test:e2e:csv:verbose": "SKILLTREE_E2E_IGNORE_MANUAL_LEVELS=1 DEBUG=pw:api playwright test e2e/csv-import-export-roundtrip.spec.js --project=chromium --reporter=list",
    "test:e2e:csv:headed:verbose": "SKILLTREE_E2E_IGNORE_MANUAL_LEVELS=1 DEBUG=pw:api playwright test e2e/csv-import-export-roundtrip.spec.js --project=chromium --headed --reporter=list",
    "test:e2e:csv:headed:verbose:ignore-segments": "SKILLTREE_E2E_IGNORE_MANUAL_LEVELS=1 SKILLTREE_E2E_IGNORE_SEGMENTS=1 DEBUG=pw:api playwright test e2e/csv-import-export-roundtrip.spec.js --project=chromium --headed --reporter=list",
    "test:e2e:csv:headless:trace:ignore-segments": "SKILLTREE_E2E_IGNORE_MANUAL_LEVELS=1 SKILLTREE_E2E_IGNORE_SEGMENTS=1 npx playwright test e2e/csv-import-export-roundtrip.spec.js --project=chromium --trace on --reporter=list",
    "test:e2e:csv:headless:trace:verbose:ignore-segments": "SKILLTREE_E2E_IGNORE_MANUAL_LEVELS=1 SKILLTREE_E2E_IGNORE_SEGMENTS=1 DEBUG=pw:api npx playwright test e2e/csv-import-export-roundtrip.spec.js --project=chromium --trace on --reporter=list",
    "test:e2e:verbose": "DEBUG=pw:api playwright test --project=chromium --reporter=list",
    "test:e2e:csv:headed:ignore-levels": "SKILLTREE_E2E_IGNORE_MANUAL_LEVELS=1 playwright test e2e/csv-import-export-roundtrip.spec.js --project=chromium --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "d3-hierarchy": "^3.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-zoom-pan-pinch": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}